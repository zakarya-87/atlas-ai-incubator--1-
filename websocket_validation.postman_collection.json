{
	"info": {
		"_postman_id": "ws-validation-suite",
		"name": "ATLAS WebSocket Validation",
		"description": "Validation suite for Socket.io WebSockets in ATLAS AI Incubator. \n\n### How to use Postman for Socket.io:\n1. Click **New** -> **WebSocket**.\n2. Select **Socket.io** from the dropdown (next to the URL bar).\n3. Enter URL: `ws://localhost:3000` or `wss://<your-dev-url>`.\n4. Click **Connect**.\n5. To join a room, go to **Message**, enter event name `joinRoom` and message `\"test-room\"`.\n6. To listen for logs, ensure the server emits `agentLog`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Socket.io Handshake (HTTP)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Response contains sid\", function () {",
							"    var rawBody = pm.response.text();",
							"    // Socket.io/Engine.io 4 handshake response starts with '0'",
							"    var jsonStr = rawBody.startsWith('0') ? rawBody.substring(1) : rawBody;",
							"    var jsonData = JSON.parse(jsonStr);",
							"    pm.expect(jsonData).to.have.property('sid');",
							"});",
							"pm.test(\"Supports WebSocket upgrade\", function () {",
							"    var rawBody = pm.response.text();",
							"    var jsonStr = rawBody.startsWith('0') ? rawBody.substring(1) : rawBody;",
							"    var jsonData = JSON.parse(jsonStr);",
							"    pm.expect(jsonData.upgrades).to.include('websocket');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3000/socket.io/?EIO=4&transport=polling",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"socket.io",
						""
					],
					"query": [
						{
							"key": "EIO",
							"value": "4"
						},
						{
							"key": "transport",
							"value": "polling"
						}
					]
				}
			},
			"response": []
		}
	]
}
