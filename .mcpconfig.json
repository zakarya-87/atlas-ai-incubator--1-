{
  "mcpServers": {
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "vercel-mcp-server"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "workspace-developer": {
      "httpUrl": "https://workspace-developer.goog/mcp",
      "trust": true
    },
    "devtool": {
      "command": "npx",
      "args": [
        "-y",
        "@standardbeagle/agnt"
      ],
      "env": {
        "AGNT_PROJECT_PATH": "c:/Users/zboud/ATLAS AI Incubator"
      }
    },
    "testsprite": {
      "command": "npx",
      "args": [
        "-y",
        "@testsprite/testsprite-mcp@latest"
      ],
      "env": {
        "API_KEY": "${TESTSPRITE_API_KEY}",
        "PROJECT_PATH": "c:/Users/zboud/ATLAS AI Incubator",
        "COVERAGE_THRESHOLD": "85",
        "EDGE_CASE_MODE": "aggressive",
        "ERROR_TESTING": "comprehensive",
        "AUTO_GENERATE": "true"
      }
    },
    "prisma": {
      "command": "npx",
      "args": [
        "-y",
        "@abiduzzaman/prisma-mcp@latest"
      ],
      "env": {
        "DATABASE_URL": "postgres://094dcb23f2fe8da3d6df08364460a79607aaac9a96dfaeed8ffaf56f98dacb80:sk_lIZKrgfQ9_00_Kq3BR2hA@db.prisma.io:5432/postgres?sslmode=require&pool=true"
      }
    }
  }
}
