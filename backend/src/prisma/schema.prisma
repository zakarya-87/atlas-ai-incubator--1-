// This is your Prisma schema file for ATLAS AI Incubator
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USER & AUTHENTICATION
// ==========================================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  fullName          String?
  role              String   @default("user") // user, admin
  credits           Int      @default(100) // For usage quotas
  subscriptionStatus String  @default("free") // free, active, cancelled, past_due
  subscriptionPlan  String   @default("free") // free, starter, pro, enterprise
  stripeCustomerId  String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  ownedVentures     Venture[]
  ventureMemberships VentureMember[]
  analyses          Analysis[]
  refreshTokens     RefreshToken[]

  @@index([email])
  @@map("users")
}

// ==========================================
// REFRESH TOKENS (for secure auth)
// ==========================================

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==========================================
// VENTURES (Projects/Businesses)
// ==========================================

model Venture {
  id          String   @id @default(uuid())
  name        String
  description String?
  industry    String?
  stage       String?  // idea, validation, mvp, growth, scale
  userId      String   // Owner
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     VentureMember[]
  analyses    Analysis[]

  @@index([userId])
  @@map("ventures")
}

// ==========================================
// VENTURE MEMBERS (Team Collaboration)
// ==========================================

model VentureMember {
  id         String   @id @default(uuid())
  ventureId  String
  userId     String
  role       String   @default("viewer") // owner, editor, viewer
  invitedBy  String?
  joinedAt   DateTime @default(now())

  // Relations
  venture    Venture  @relation(fields: [ventureId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ventureId, userId])
  @@index([ventureId])
  @@index([userId])
  @@map("venture_members")
}

// ==========================================
// ANALYSIS (AI-Generated Content)
// ==========================================

model Analysis {
  id           String   @id @default(uuid())
  ventureId    String
  userId       String
  module       String   // strategy, marketAnalysis, finance, etc.
  tool         String   // swot, pestel, budgetGenerator, etc.
  inputContext String   @db.Text // User's business description
  resultData   Json     // Structured analysis result
  parentId     String?  // For refinement/versioning
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  venture      Venture  @relation(fields: [ventureId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Analysis? @relation("AnalysisVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children     Analysis[] @relation("AnalysisVersions")

  @@index([ventureId])
  @@index([userId])
  @@index([module])
  @@index([tool])
  @@index([createdAt])
  @@index([parentId])
  @@map("analyses")
}

// ==========================================
// INTEGRATIONS (External Services)
// ==========================================

model Integration {
  id         String   @id @default(uuid())
  userId     String
  provider   String   // slack, notion, gdrive, etc.
  status     String   @default("disconnected") // connected, disconnected
  tokens     Json?    // OAuth tokens (encrypted in practice)
  metadata   Json?    // Additional config
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

// ==========================================
// SUBSCRIPTIONS (Stripe)
// ==========================================

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeSubscriptionId String   @unique
  plan                 String   // starter, pro, enterprise
  status               String   // active, cancelled, past_due, trialing
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// ==========================================
// AUDIT TRAIL (Optional - for compliance)
// ==========================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity    String   // User, Venture, Analysis, etc.
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
