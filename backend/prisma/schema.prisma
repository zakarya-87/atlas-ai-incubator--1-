// This is your Prisma schema file for ATLAS AI Incubator
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ==========================================
// KNOWLEDGE BASE (RAG Support)
// ==========================================

model Document {
  id        BigInt   @id @default(autoincrement())
  content   String
  metadata  Json?
  embedding Unsupported("vector(768)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

// ==========================================
// USER & AUTHENTICATION
// ==========================================

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  fullName           String?
  role               String         @default("USER") // USER, ADMIN
  credits            Int            @default(100) // For usage quotas
  subscriptionStatus String         @default("free") // free, active, cancelled, past_due
  subscriptionPlan   String         @default("free") // free, starter, pro, enterprise
  stripeCustomerId   String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  ownedVentures      Venture[]
  ventureMemberships VentureMember[]
  analyses           Analysis[]
  refreshTokens      RefreshToken[]
  jobs               Job[]

  @@index([email])
  @@map("users")
}

// ==========================================
// REFRESH TOKENS (for secure auth)
// ==========================================

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==========================================
// VENTURES (Projects/Businesses)
// ==========================================

model Venture {
  id          String          @id @default(uuid())
  name        String
  description String?
  industry    String?
  stage       String? // idea, validation, mvp, growth, scale
  userId      String // Owner
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  owner       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     VentureMember[]
  analyses    Analysis[]

  @@index([userId])
  @@map("ventures")
}

// ==========================================
// VENTURE MEMBERS (Team Collaboration)
// ==========================================

model VentureMember {
  id        String   @id @default(uuid())
  ventureId String
  userId    String
  role      String   @default("viewer") // owner, editor, viewer
  invitedBy String?
  joinedAt  DateTime @default(now())
  venture   Venture  @relation(fields: [ventureId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ventureId, userId])
  @@index([ventureId])
  @@index([userId])
  @@map("venture_members")
}

// ==========================================
// ANALYSIS (AI-Generated Content)
// ==========================================

model Analysis {
  id           String    @id @default(uuid())
  ventureId    String
  userId       String
  module       String // strategy, marketAnalysis, finance, etc.
  tool         String // swot, pestel, budgetGenerator, etc.
  inputContext String // User's business description
  resultData   String // Structured analysis result (JSON string)
  parentId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  venture      Venture   @relation(fields: [ventureId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Analysis? @relation("AnalysisVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children     Analysis[] @relation("AnalysisVersions")

  @@index([ventureId])
  @@index([userId])
  @@index([module])
  @@index([tool])
  @@index([createdAt])
  @@index([parentId])
  @@map("analyses")
}

// ==========================================
// INTEGRATIONS (External Services)
// ==========================================

model Integration {
  id        String   @id @default(uuid())
  ventureId String
  provider  String // slack, notion, gdrive, etc.
  status    String   @default("disconnected") // connected, disconnected
  config    String?  // Configuration data (JSON string)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ventureId, provider])
  @@index([ventureId])
  @@map("integrations")
}

// ==========================================
// SUBSCRIPTIONS (Stripe)
// ==========================================

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeSubscriptionId String   @unique
  plan                 String // starter, pro, enterprise
  status               String // active, cancelled, past_due, trialing
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// ==========================================
// BACKGROUND JOBS (For async processing)
// ==========================================

model Job {
  id          String    @id @default(uuid())
  userId      String
  type        String // e.g., 'analysis-generate', 'report-export'
  status      String // pending, processing, completed, failed
  input       String? // Job input data (JSON string)
  result      String? // Job result data (JSON string)
  error       String? // Error message if job failed
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("jobs")
}

// ==========================================
// AUDIT TRAIL (Optional - for compliance)
// ==========================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity    String // User, Venture, Analysis, etc.
  entityId  String?
  metadata  String? // (JSON string)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
