{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "atlas-ai-container-group",
      "metadata": {
        "description": "Name for the container group"
      }
    },
    "frontendImage": {
      "type": "string",
      "defaultValue": "atlas-frontend:latest",
      "metadata": {
        "description": "Container image for the frontend"
      }
    },
    "backendImage": {
      "type": "string",
      "defaultValue": "atlas-backend:latest",
      "metadata": {
        "description": "Container image for the backend"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "frontendPort": {
      "type": "int",
      "defaultValue": 80,
      "metadata": {
        "description": "Port for the frontend container"
      }
    },
    "backendPort": {
      "type": "int",
      "defaultValue": 3000,
      "metadata": {
        "description": "Port for the backend container"
      }
    },
    "databaseUrl": {
      "type": "securestring",
      "metadata": {
        "description": "Database connection string"
      }
    },
    "jwtSecret": {
      "type": "securestring",
      "metadata": {
        "description": "JWT secret for authentication"
      }
    },
    "apiKey": {
      "type": "securestring",
      "metadata": {
        "description": "API Key for the application"
      }
    },
    "registryServer": {
      "type": "string",
      "defaultValue": "atlasairegistry.azurecr.io",
      "metadata": {
        "description": "The registry server URL"
      }
    },
    "registryUsername": {
      "type": "string",
      "metadata": {
        "description": "The registry username"
      }
    },
    "registryPassword": {
      "type": "securestring",
      "metadata": {
        "description": "The registry password"
      }
    },
    "dnsNameLabel": {
      "type": "string",
      "defaultValue": "atlas-ai-incubator",
      "metadata": {
        "description": "The DNS name label for the container group"
      }
    }
  },
  "variables": {},
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2021-09-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "imageRegistryCredentials": [
          {
            "server": "[parameters('registryServer')]",
            "username": "[parameters('registryUsername')]",
            "password": "[parameters('registryPassword')]"
          }
        ],
        "containers": [
          {
            "name": "atlas-frontend",
            "properties": {
              "image": "[parameters('frontendImage')]",
              "ports": [
                {
                  "port": "[parameters('frontendPort')]",
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "VITE_BACKEND_URL",
                  "value": "[concat('http://', parameters('dnsNameLabel'), '.', parameters('location'), '.azurecontainer.io:', parameters('backendPort'))]"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGb": 2
                }
              }
            }
          },
          {
            "name": "atlas-backend",
            "properties": {
              "image": "[parameters('backendImage')]",
              "ports": [
                {
                  "port": "[parameters('backendPort')]",
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "DATABASE_URL",
                  "secureValue": "[parameters('databaseUrl')]"
                },
                {
                  "name": "JWT_SECRET",
                  "secureValue": "[parameters('jwtSecret')]"
                },
                {
                  "name": "API_KEY",
                  "secureValue": "[parameters('apiKey')]"
                },
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "REDIS_HOST",
                  "value": "localhost"
                },
                {
                  "name": "REDIS_PORT",
                  "value": "6379"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGb": 2
                }
              }
            }
          },
          {
            "name": "postgres",
            "properties": {
              "image": "[concat(parameters('registryServer'), '/postgres:16-alpine')]",
              "ports": [
                {
                  "port": 5432,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "POSTGRES_USER",
                  "value": "atlas_user"
                },
                {
                  "name": "POSTGRES_PASSWORD",
                  "value": "atlas_secure_password_2026"
                },
                {
                  "name": "POSTGRES_DB",
                  "value": "atlas_prod_db"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGb": 1
                }
              }
            }
          },
          {
            "name": "redis",
            "properties": {
              "image": "[concat(parameters('registryServer'), '/redis:alpine')]",
              "ports": [
                {
                  "port": 6379,
                  "protocol": "TCP"
                }
              ],
              "resources": {
                "requests": {
                  "cpu": 0.5,
                  "memoryInGb": 0.5
                }
              }
            }
          }
        ],
        "osType": "Linux",
        "ipAddress": {
          "type": "Public",
          "dnsNameLabel": "[parameters('dnsNameLabel')]",
          "ports": [
            {
              "protocol": "TCP",
              "port": "[parameters('frontendPort')]"
            },
            {
              "protocol": "TCP",
              "port": "[parameters('backendPort')]"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "frontendIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.ip]"
    },
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.fqdn]"
    }
  }
}