NODE_ENV=development
PORT=5173
FRONTEND_URL=http://localhost:5173

# Database (replace with your managed PostgreSQL connection string)
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME

# Secrets
API_KEY=your-api-key-here
JWT_SECRET=your-strong-random-string-here

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (optional)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASSWORD

# TestSprite MCP Server (optional - for cloud test execution)
# Get your API key from: https://www.testsprite.com/dashboard
TESTSPRITE_API_KEY=your-testsprite-api-key

# AI Providers Configuration
# Default provider: gemini, grok, or mistral
DEFAULT_AI_PROVIDER=gemini

# Gemini AI - Get API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# Grok (xAI) - Get API key from https://console.x.ai/
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-beta

# Mistral AI - Get API key from https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest

# Azure OpenAI Configuration - Get from Azure Portal
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_MODEL=gpt-4

# Vercel MCP Server
VERCEL_TOKEN=
